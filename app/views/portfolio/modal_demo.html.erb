<%= turbo_frame_tag "turbo_demo" do %>
  <div class="rounded-lg border border-[#CC342D]/35 bg-[#CC342D]/10 p-4">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="font-mono text-xs text-[#CC342D]">turbo frame response</p>
        <h4 class="mt-1 font-semibold text-white">Modal content streamed from Rails</h4>
        <p class="mt-2 text-sm leading-6 text-[#F5F2EB]/65">The request replaced only this frame, preserving search input, clock state, scroll position, and every other interaction on the page.</p>
      </div>
      <button type="button" class="rounded-lg border border-white/10 px-3 py-1 font-mono text-xs text-[#F5F2EB]/70" onclick="this.closest('turbo-frame').innerHTML = ''">esc</button>
    </div>
  </div>
<% end %>
