<% content_for :title, "Terminal - #{@profile[:name]}" %>

<div class="min-h-screen bg-black px-4 py-6 font-mono text-emerald-200 sm:px-6 lg:px-8" data-controller="terminal" data-terminal-commands-value="<%= @terminal_commands.to_json %>">
  <div class="mx-auto max-w-5xl">
    <div class="mb-4 flex items-center justify-between text-xs text-emerald-200/55">
      <%= link_to "<- portfolio", root_path, class: "hover:text-emerald-100" %>
      <span>ssh guest@sureshsharma.dev</span>
    </div>

    <section class="terminal-page min-h-[78vh] rounded-lg border border-emerald-400/20 bg-[#020402] shadow-2xl shadow-emerald-950/30">
      <div class="flex items-center justify-between border-b border-emerald-400/15 px-4 py-3">
        <div class="flex gap-2" aria-hidden="true">
          <span class="h-3 w-3 rounded-full bg-[#CC342D]"></span>
          <span class="h-3 w-3 rounded-full bg-amber-300"></span>
          <span class="h-3 w-3 rounded-full bg-emerald-400"></span>
        </div>
        <span class="text-xs text-emerald-200/45">interactive shell</span>
      </div>

      <div class="h-[62vh] overflow-y-auto p-5 text-sm leading-7" data-terminal-target="output" aria-live="polite">
        <p>Rails portfolio shell initialized.</p>
        <p>Type <span class="text-white">help</span> to list commands.</p>
      </div>

      <form class="flex items-center gap-3 border-t border-emerald-400/15 p-5" data-action="submit->terminal#submit">
        <label for="terminal-input" class="shrink-0 text-emerald-300">guest@suresh:~$</label>
        <input id="terminal-input" data-terminal-target="input" data-action="keydown->terminal#historySearch" class="min-w-0 flex-1 bg-transparent text-white outline-none placeholder:text-emerald-200/25" autocomplete="off" autofocus placeholder="whoami">
      </form>
    </section>
  </div>
</div>
